{
    "name": "ip-api-io/ipapi-php",
    "description": "Official PHP client for ip-api.io — IP geolocation, email validation, fraud detection and risk scoring API",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ip geolocation",
        "ip api",
        "geoip",
        "email validation",
        "fraud detection",
        "risk score",
        "vpn detection",
        "tor detection",
        "whois",
        "asn lookup"
    ],
    "homepage": "https://ip-api.io",
    "support": {
        "issues": "https://github.com/ip-api-io/ipapi-php/issues",
        "source": "https://github.com/ip-api-io/ipapi-php",
        "docs": "https://ip-api.io/docs"
    },
    "authors": [
        {
            "name": "ip-api.io",
            "homepage": "https://ip-api.io"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "IpApiIo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IpApiIo\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
